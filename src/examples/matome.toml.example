# matome configuration

[core]
data_dir = "./.matome"

[[domain]]
url = "https://docs.rust-lang.org"
include = ["/stable/**"]

[[domain]]
url = "https://kubernetes.io/docs"
include = ["/**"]

[translate]
provider = "ollama"
model = "translategemma:latest"
target_lang = "ja"
glossary_file = "glossary.toml"

[crawl]
concurrency = 8
respect_robots = true
timeout = 30
max_pages = 0
