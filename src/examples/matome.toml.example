# matome configuration
#
# Note: All keys use kebab-case (e.g., data-dir, target-lang).
# snake_case also works for backward compatibility.

[core]
data-dir = ".matome"

[[domain]]
url = "https://docs.rust-lang.org"
include = ["/stable/**"]

[[domain]]
url = "https://kubernetes.io/docs"
include = ["/**"]

[translate]
provider = "ollama"
model = "translategemma:4b"
target-lang = "ja"
glossary-file = "glossary.toml"

[crawl]
concurrency = 8
respect-robots = true
timeout = 30
max-pages = 0
